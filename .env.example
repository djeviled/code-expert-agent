# Code Expert Agent — Environment Variables
# Copy this to .env (local dev) or add as Vercel project environment variables.
# NEVER commit your actual .env file to git.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/pbfkqyrplcdzbnetfwjm/settings/api
SUPABASE_URL=https://pbfkqyrplcdzbnetfwjm.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key_here

# Frontend (Vite) — same URL, use anon/public key
VITE_SUPABASE_URL=https://pbfkqyrplcdzbnetfwjm.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_public_key_here

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...your_stripe_secret_key_here

# Get from: https://dashboard.stripe.com/webhooks
# Create a webhook endpoint pointing to: https://your-domain.vercel.app/api/stripe/webhook
# Select events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...your_webhook_secret_here

# Pre-configured balance price IDs (already set up in your Stripe dashboard)
STRIPE_SITE_BALANCE_PRICE_ID=price_1TQt0aGusAHZYXWWVlliF9Qd
STRIPE_CODE_BALANCE_PRICE_ID=price_1TQt0aGusAHZYXWWaopyNgvy
STRIPE_BUNDLE_BALANCE_PRICE_ID=price_1TQt0aGusAHZYXWWxEwTktKL

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...your_anthropic_key_here

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
